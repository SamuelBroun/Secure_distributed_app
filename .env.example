# PLAYERMIND – משתני סביבה

# --- Supabase (צד לקוח, חשופים לדפדפן – ולכן רק anon key) ---
# Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- מאמן ה-AI (צד שרת בלבד! ללא קידומת VITE_, לא נחשף לדפדפן) ---
# נדרש כדי להפעיל את מוח ה-AI האמיתי. ללא המפתח – האפליקציה עובדת
# במצב fallback עם תובנות מבוססות-חוקים.
# AI_PROVIDER: anthropic (ברירת מחדל) או openai
AI_PROVIDER=anthropic
AI_API_KEY=your-llm-api-key
# AI_MODEL אופציונלי. ברירת מחדל: claude-3-5-sonnet-latest (anthropic) / gpt-4o-mini (openai)
AI_MODEL=claude-3-5-sonnet-latest
